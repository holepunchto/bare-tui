66mвҖў\u001b[0m \u001b[1m\u001b[36mprogram.js\u001b[0m\u001b[0m вҖ” the runtime / event loop\u001b[22;1H\u001b[K   \u001b[38;2;255;140;66mвҖў\u001b[0m \u001b[1m\u001b[36mstyle.js\u001b[0m\u001b[0m вҖ” ANSI-aware layout & styling (this banner uses it)\u001b[23;1H\u001b[K   \u001b[38;2;255;140;66mвҖў\u001b[0m \u001b[1m\u001b[36mcomponents/\u001b[0m\u001b[0m вҖ” composable models like the one drawing this menu\u001b[24;1H\u001b[K   \u001b[25;1H\u001b[K   Ask me to \u001b[3madd\u001b[0m, \u001b[3mfix\u001b[0m, or \u001b[3mtest\u001b[0m something to watch the tool loop run.\u001b[27;1H\u001b[K \u001b[1mcommands\u001b[0m\u001b[28;1H\u001b[K   \u001b[38;2;238;111;248m/help    \u001b[0m \u001b[2mshow what this demo can do\u001b[0m\u001b[29;1H\u001b[K   \u001b[38;2;238;111;248m/clear   \u001b[0m \u001b[2mclear the conversation\u001b[0m\u001b[30;1H\u001b[K   \u001b[38;2;238;111;248m/model   \u001b[0m \u001b[2mcycle the (pretend) model\u001b[0m\u001b[31;1H\u001b[K   \u001b[38;2;238;111;248m/theme   \u001b[0m \u001b[2mcycle the color theme\u001b[0m\u001b[32;1H\u001b[K   \u001b[38;2;238;111;248m/cost    \u001b[0m \u001b[2mshow token usage so far\u001b[0m\u001b[33;1H\u001b[K   \u001b[38;2;238;111;248m/compact \u001b[0m \u001b[2msummarize & shrink the transcript\u001b[0m\u001b[34;1H\u001b[K   \u001b[38;2;238;111;248m/quit    \u001b[0m \u001b[2mexit the demo\u001b[0m\u001b[35;1H\u001b[K \u001b[36;1H\u001b[K \u001b[1mkeys\u001b[0m\u001b[37;1H\u001b[K   \u001b[38;2;238;111;248menter   \u001b[0m \u001b[2msend / accept a suggestion\u001b[0m\u001b[38;1H\u001b[K   \u001b[38;2;238;111;248mpgup/dn \u001b[0m \u001b[2mscroll the transcript (or mouse wheel)\u001b[0m\u001b[39;1H\u001b[K   \u001b[38;2;238;111;248mesc     \u001b[0m \u001b[2minterrupt a running task\u001b[0m\u001b[40;1H\u001b[K   \u001b[38;2;238;111;248mctrl+c  \u001b[0m \u001b[2minterrupt, or quit when idle\u001b[0m\u001b[42;1H\u001b[K\u001b[38;2;238;111;248mв”Ӯ\u001b[0m \u001b[1;38;2;248;87;166mвқҜ\u001b[0m\u001b[1;38;2;255;140